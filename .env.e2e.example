# Live e2e battle-test credentials (cp .env.e2e.example .env.e2e — NEVER commit .env.e2e).
# Point these at a NON-PRODUCTION tenant. The suites create and delete real
# objects (request types, form templates, automation rules, a Confluence space
# with key GOJIRAE2E) and leave the tenant clean on success.

E2E_SITE_URL=your-site.atlassian.net
E2E_CLOUD_ID=            # https://<site>.atlassian.net/_edge/tenant_info
E2E_EMAIL=               # account that owns the API token — must be a Jira admin
E2E_API_TOKEN=           # https://id.atlassian.com/manage-profile/security/api-tokens
E2E_ACCOUNT_ID=          # the account's Atlassian accountId (optional but recommended)
E2E_OAUTH_ACCESS_TOKEN=  # optional: enables the OAuth-path suites (jira core, custom fields)

# Assets/CMDB is Premium-only — the assets e2e suite skips unless you opt in on a
# Premium tenant whose OAuth app has the CMDB scopes:
E2E_ASSETS=              # set to 1 to run the Assets read-plane checks
E2E_ASSETS_OBJECT_TYPE_ID=   # + a writable object type id to run the object round-trip
E2E_ASSETS_NAME_ATTR_ID=     # + that type's "Name" objectTypeAttributeId

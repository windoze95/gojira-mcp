# --- Atlassian OAuth (3LO) ---
ATLASSIAN_OAUTH_CLIENT_ID=
ATLASSIAN_OAUTH_CLIENT_SECRET=
# Optional; defaults to ${MCP_SERVER_URL}/oauth/atlassian-callback
ATLASSIAN_CALLBACK_URI=

# Atlassian OAuth scopes this deployment requests upstream at /authorize.
# Space-separated. `offline_access` is REQUIRED for refresh tokens to come back.
# The set you list here must be a subset of what the Atlassian developer-console
# OAuth app declares.
ATLASSIAN_OAUTH_SCOPES=offline_access read:me read:account read:jira-work write:jira-work manage:jira-project manage:jira-configuration read:servicedesk-request write:servicedesk-request manage:servicedesk-customer

# Site pinning. Reject any tool invocation whose target cloudId differs from
# this value. Strongly recommended in production.
ATLASSIAN_PINNED_CLOUD_ID=

# --- Org-admin (admin.atlassian.com) gate ---
GOJIRA_ENABLE_ORG_ADMIN=false
GOJIRA_ORG_ADMIN_TOKEN=
GOJIRA_ORG_ID=

# --- Audit ---
# stdout | file:/path | http:URL | syslog:facility
GOJIRA_AUDIT_LOG_TARGET=stdout
# Optional separate sink for org-admin operations (recommended). Inherits main if unset.
GOJIRA_ORG_ADMIN_AUDIT_LOG_TARGET=

# --- Operation journal ---
GOJIRA_OPERATION_JOURNAL_TTL_DAYS=30

# --- Operator allowlist: permission groups this deployment WILL register ---
# Comma-separated. REQUIRED — no implicit default. The value names exactly
# the surface this deployment exposes; least-privilege by default. Examples:
#   # Default safe (admin sandbox — no project deletion, no org admin):
#   GOJIRA_ENABLED_GROUPS=utility,read_jsm_admin,write_jsm_admin,read_assets,write_assets,read_automation,write_automation,read_customfields,write_customfields,read_projects,write_projects,read_schemes,write_schemes,read_workflows,write_workflows,read_confluence_admin,write_confluence_admin,read_agile,write_agile,read_filters_dashboards,write_filters_dashboards
#   # Read-only audit:
#   GOJIRA_ENABLED_GROUPS=utility,read_jsm_admin,read_assets,read_automation,read_customfields,read_projects,read_schemes,read_workflows,read_confluence_admin,read_agile,read_filters_dashboards
#   # JSM/Assets specialist:
#   GOJIRA_ENABLED_GROUPS=utility,read_jsm_admin,write_jsm_admin,read_assets,write_assets
#   # Org-admin (separate host; also requires GOJIRA_ENABLE_ORG_ADMIN=true):
#   GOJIRA_ENABLED_GROUPS=utility,admin_org
GOJIRA_ENABLED_GROUPS=utility,read_jsm_admin,write_jsm_admin,read_assets,write_assets,read_automation,write_automation,read_customfields,write_customfields,read_projects,write_projects,read_schemes,write_schemes,read_workflows,write_workflows,read_confluence_admin,write_confluence_admin,read_agile,write_agile,read_filters_dashboards,write_filters_dashboards

# --- Refresh-token reuse alerting ---
GOJIRA_REFRESH_REUSE_ALERT_WEBHOOK=

# --- Foundation ---
TOKEN_ENCRYPTION_KEY=
REDIS_URL=redis://localhost:6379
# Docker-compose only — Redis sidecar binds this in --requirepass and the app
# connects via redis://:${REDIS_PASSWORD}@redis:6379 (set in docker-compose.yml).
REDIS_PASSWORD=
MCP_PORT=8081
MCP_SERVER_URL=http://localhost:8081
NODE_ENV=development
LOG_LEVEL=info
RATE_LIMIT_PER_USER=60
TLS_CERT_PATH=
TLS_KEY_PATH=
ALLOWED_ORIGINS=*

# Tuning: Atlassian NearLimit feedback — extra tokens to deduct when the
# upstream signals near-rate-limit.
GOJIRA_NEAR_LIMIT_EXTRA_DEDUCT=5

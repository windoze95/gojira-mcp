# gojira-mcp — NON-PROD / sandbox instance profile
# cp deploy/nonprod.env.example .env.nonprod && fill in; run with:
#   docker compose -p gojira-nonprod --env-file .env.nonprod \
#     -f docker-compose.yml -f docker-compose.caddy.yml up -d
#
# Full tool surface — this is where new groups and upgrades soak before prod.
# Point it ONLY at the sandbox tenant (the pinned cloudId enforces that).

GOJIRA_ENV_FILE=.env.nonprod
NODE_ENV=production   # posture stays hardened even on the sandbox instance

# ── OAuth app (a separate app registered against the sandbox site)
ATLASSIAN_OAUTH_CLIENT_ID=
ATLASSIAN_OAUTH_CLIENT_SECRET=
# Scope set for the full surface below (see docs/deployment/turnkey-setup.md §3).
# This profile enables read_assets/write_assets, and Assets IS OAuth-authed: it needs
# the 13 CMDB *granular* scopes (Jira → Granular scopes tab) plus read:servicedesk-request,
# which covers the workspace-discovery call GET /rest/servicedeskapi/assets/workspace that
# every assets.* tool runs before its data call. Miss it and all of them fail.
# JSM-admin/forms, Confluence-admin and automation ride the per-user API token — they
# consume no OAuth scope, which is why write:servicedesk-request / manage:servicedesk-customer
# are absent.
ATLASSIAN_OAUTH_SCOPES=offline_access read:me read:account read:jira-work write:jira-work manage:jira-project manage:jira-configuration read:servicedesk-request read:cmdb-object:jira write:cmdb-object:jira read:cmdb-schema:jira write:cmdb-schema:jira read:cmdb-type:jira write:cmdb-type:jira read:cmdb-attribute:jira write:cmdb-attribute:jira delete:cmdb-object:jira delete:cmdb-schema:jira delete:cmdb-type:jira delete:cmdb-attribute:jira import:import-configuration:cmdb

# ── Identity of THIS instance
ATLASSIAN_PINNED_CLOUD_ID=   # the SANDBOX tenant's cloudId
MCP_SERVER_URL=https://gojira-sandbox.example.com
CADDY_DOMAIN=gojira-sandbox.example.com
ALLOWED_ORIGINS=https://your-mcp-client.example.com

# ── Secrets (independent from prod)
TOKEN_ENCRYPTION_KEY=        # npm run generate-key
REDIS_PASSWORD=

# ── Tool surface: everything except org-admin and project deletion.
GOJIRA_ENABLED_GROUPS=utility,read_jsm_admin,write_jsm_admin,read_assets,write_assets,read_automation,write_automation,read_customfields,write_customfields,read_projects,write_projects,read_schemes,write_schemes,read_workflows,write_workflows,read_confluence_admin,write_confluence_admin,read_agile,write_agile,read_filters_dashboards,write_filters_dashboards

GOJIRA_ENABLE_ORG_ADMIN=false

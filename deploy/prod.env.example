# gojira-mcp — PRODUCTION instance profile
# cp deploy/prod.env.example .env.prod && fill in; run with:
#   docker compose -p gojira-prod --env-file .env.prod \
#     -f docker-compose.yml -f docker-compose.caddy.yml up -d
#
# Conservative-by-default: read groups + the daily JSM/forms surface. Widen
# GOJIRA_ENABLED_GROUPS deliberately, one group at a time, after the same
# groups have soaked on the non-prod instance.

GOJIRA_ENV_FILE=.env.prod
NODE_ENV=production

# ── OAuth app (register per environment — never share the prod app with sandbox)
ATLASSIAN_OAUTH_CLIENT_ID=
ATLASSIAN_OAUTH_CLIENT_SECRET=
# Scope set for the groups below (see docs/deployment/turnkey-setup.md §3).
# Confluence/automation/forms/JSM-admin ride the per-user API token — no OAuth
# scopes needed for them, so no *:servicedesk-request / manage:servicedesk-customer
# here: nothing in this profile presents an OAuth bearer to a servicedesk API.
# (The Jira write scopes are already listed for the write_* groups in the
# "widen when ready" note below.)
ATLASSIAN_OAUTH_SCOPES=offline_access read:me read:account read:jira-work write:jira-work manage:jira-project manage:jira-configuration
#
# If you ever enable read_assets/write_assets, Assets IS OAuth-authed — append the
# 13 CMDB granular scopes AND read:servicedesk-request (the workspace-discovery call
# GET /rest/servicedeskapi/assets/workspace, which every assets.* tool runs first):
#   read:cmdb-object:jira write:cmdb-object:jira read:cmdb-schema:jira write:cmdb-schema:jira
#   read:cmdb-type:jira write:cmdb-type:jira read:cmdb-attribute:jira write:cmdb-attribute:jira
#   delete:cmdb-object:jira delete:cmdb-schema:jira delete:cmdb-type:jira delete:cmdb-attribute:jira
#   import:import-configuration:cmdb
#   read:servicedesk-request

# ── Identity of THIS instance
# Pin the production cloudId — the server refuses calls to any other tenant.
ATLASSIAN_PINNED_CLOUD_ID=
MCP_SERVER_URL=https://gojira.example.com
CADDY_DOMAIN=gojira.example.com
ALLOWED_ORIGINS=https://your-mcp-client.example.com

# ── Secrets (generate fresh per environment; never reuse non-prod values)
TOKEN_ENCRYPTION_KEY=        # npm run generate-key
REDIS_PASSWORD=

# ── Tool surface: production default = reads + JSM/forms daily admin.
GOJIRA_ENABLED_GROUPS=utility,read_jsm_admin,write_jsm_admin,read_projects,read_schemes,read_workflows,read_customfields,read_confluence_admin,read_agile,read_filters_dashboards,read_automation

# Widen when ready, e.g. append:
#   write_projects,write_schemes,write_workflows,write_customfields,
#   write_confluence_admin,write_agile,write_filters_dashboards,write_automation

# Org-admin tools stay OFF in prod unless run as a separate, isolated instance
# (see turnkey-setup.md §12).
GOJIRA_ENABLE_ORG_ADMIN=false
